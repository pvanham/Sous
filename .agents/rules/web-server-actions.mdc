## Service layer — business logic + Mongoose

```ts
// src/server/services/shift.service.ts
import Shift from "@/server/models/Shift";
import { Types } from "mongoose";
import { toShiftDTO } from "@/types/shift";
import type { ShiftDTO, CreateShiftInput } from "@/types/shift";

export const ShiftService = {
  async create(data: CreateShiftInput): Promise<ShiftDTO> {
    const hasOverlap = await this.checkOverlap(
      data.orgId,
      data.locationId,
      data.staffId,
      data.start,
      data.end
    );
    if (hasOverlap) {
      throw new Error("This shift overlaps with an existing shift for this staff member");
    }

    const doc = await Shift.create({
      orgId: new Types.ObjectId(data.orgId),
      locationId: new Types.ObjectId(data.locationId),
      scheduleId: new Types.ObjectId(data.scheduleId),
      staffId: new Types.ObjectId(data.staffId),
      start: data.start,
      end: data.end,
      station: data.station,
      notes: data.notes || "",
    });

    return toShiftDTO(doc.toObject());
  },

  // More methods…
};
```

### Hard rules for services

- Services are exported as **plain objects with method properties**, not
  classes. `export const ShiftService = { ... }`.
- Services are the **only** consumers of `src/server/models/*`.
- Convert string IDs to `new Types.ObjectId(id)` **inside** the service,
  before hitting Mongo.
- Return **DTOs**, never Mongoose documents. Use the feature-local
  `toXDTO(doc.toObject())` helper.
- Services may call other services. Avoid circular dependencies by
  pushing shared logic to a lower service (e.g.
  `organization.service.ts`).
- Services throw on business-rule violations. The action catches and
  converts to `ActionResponse<T>`.
- Queries that return lists must use `.lean()` when the Mongoose
  document methods aren't needed — it's faster and less memory.

