{
  "name": "@sous/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "expo start",
    "dev:client": "expo start --dev-client",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "ios:client": "expo start --ios --dev-client",
    "build:ios:dev": "npx eas-cli build --platform ios --profile development",
    "build:ios:sim": "npx eas-cli build --platform ios --profile development-simulator",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.36",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/material-top-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@sous/config": "*",
    "@sous/types": "*",
    "@tanstack/react-query": "^5.90.19",
    "axios": "^1.15.0",
    "expo": "~55.0.20",
    "expo-auth-session": "~55.0.15",
    "expo-constants": "~55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.32",
    "expo-device": "^55.0.16",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.9",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.14",
    "expo-notifications": "^55.0.22",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "nativewind": "^5.0.0-preview.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.83.6",
    "react-native-css": "^3.0.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.4",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.2"
  }
