# ─────────────────────────────────────────────────────────────
# Sous — Mobile app environment variables
# Copy to .env (or .env.local) and fill in the values.
# Expo only exposes variables prefixed with EXPO_PUBLIC_ to the
# client bundle.
# ─────────────────────────────────────────────────────────────

# Clerk publishable key (required). Use the SAME Clerk instance
# as the web app so sessions and users line up.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Base URL the mobile app hits for the web API (auth-protected).
# - iOS simulator:       http://localhost:3000/api
# - Android emulator:    http://10.0.2.2:3000/api
# - Physical device:     http://<your-mac-ip>:3000/api
# - Production:          https://<your-deployed-web-origin>/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api
