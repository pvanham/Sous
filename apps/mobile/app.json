{
  "expo": {
    "name": "Sous",
    "slug": "sous-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sous",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sous.mobile",
      "associatedDomains": [
        "applinks:localhost:3000"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Sous needs access to your photos so you can choose a profile picture.",
        "NSCameraUsageDescription": "Sous needs access to your camera so you can take a new profile picture."
      }
    },
    "android": {
      "package": "com.sous.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#1c1917",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "localhost:3000",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1c1917",
          "dark": {
            "backgroundColor": "#1c1917"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Sous needs access to your photos so you can choose a profile picture.",
          "cameraPermission": "Sous needs access to your camera so you can take a new profile picture.",
          "microphonePermission": false
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#1c1917",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "77ba47ab-245f-4861-a728-eeec5b309fc1"
      }
    }
  }
}
