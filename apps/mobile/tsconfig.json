{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@sous/types": ["../../packages/types/src/index.ts"],
      "@sous/types/*": ["../../packages/types/src/*"],
      "@sous/config/*": ["../../packages/config/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
