# ─────────────────────────────────────────────────────────────
# Sous — Web app environment variables
# Copy to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────

# Clerk (required)
# Grab from the Clerk dashboard -> API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk webhook signing secret (required for /api/webhooks/clerk)
# Create a webhook in the Clerk dashboard pointing at
# <your-app>/api/webhooks/clerk and copy the signing secret here.
CLERK_WEBHOOK_SECRET=whsec_...

# Base URL used when generating Clerk invitation redirects.
# Local dev:  http://localhost:3000
# Production: your deployed web origin (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB (required)
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>

# OpenAI (required for AI schedule generation)
OPENAI_API_KEY=sk-proj-...

# Optional: Constraint solver microservice
# CP_SOLVER_URL=http://localhost:8000

# Optional: Stripe (billing)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Notifications (optional, but required for delivery) ────
# Resend transactional email API key — leave unset and the
# dispatcher will skip every email send while still firing pushes.
# Get one from https://resend.com/api-keys (free tier is plenty).
# RESEND_API_KEY=re_...
# Default From address for outbound notifications. Use Resend's
# onboarding domain for dev (`onboarding@resend.dev`); switch to
# your verified sending domain in production.
# RESEND_FROM="Sous <notifications@yourdomain.com>"
#
# Expo push access token. Optional — without it Expo accepts
# pushes anonymously up to a generous rate limit; the token raises
# that limit and lets us inspect receipts. Generate one at
# https://expo.dev/accounts/<account>/settings/access-tokens.
# EXPO_ACCESS_TOKEN=...

# ── Seed scripts (optional) ──────────────────────────────────
# Clerk user id that will own seeded schedule-generation data.
# SEED_CLERK_USER_ID=user_...
# SEED_CLERK_USER_ID2=user_...
