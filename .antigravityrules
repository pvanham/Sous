# Code Patterns

## Server Actions

```typescript
// src/server/actions/example.actions.ts
"use server";

import { auth } from "@clerk/nextjs/server";
import { exampleSchema } from "@/lib/validations/example.schema";
import { ExampleService } from "@/server/services/example.service";
import { getLocationContext } from "@/lib/auth/get-location-context";
import type { ActionResponse } from "@/lib/safe-action";

export async function createExample(
  input: unknown
): Promise<ActionResponse<ExampleDTO>> {
  // 1. Auth check
  const { userId } = await auth();
  if (!userId) {
    return { success: false, error: "Unauthorized" };
  }

  // 2. Validation
  const parsed = exampleSchema.safeParse(input);
  if (!parsed.success) {
    return { success: false, error: parsed.error.message };
  }

  // 3. Get location context (handles DB connection)
  const ctx = await getLocationContext(userId);

  // 4. Service call with orgId + locationId
  try {
    const result = await ExampleService.create(ctx.orgId, ctx.locationId, parsed.data);
    return { success: true, data: result };
  } catch (error) {
    return { 
      success: false, 
      error: error instanceof Error ? error.message : "Unknown error" 
    };
  }
}
```

## Service Layer

All services use `(orgId, locationId)` for multi-location scoping:

```typescript
// src/server/services/example.service.ts
import { Types } from "mongoose";
import Example from "@/server/models/Example";
import { toExampleDTO } from "@/types/example";
import type { ExampleDTO, ExampleInput } from "@/types/example";

export const ExampleService = {
  async create(orgId: string, locationId: string, data: ExampleInput): Promise<ExampleDTO> {
    const doc = await Example.create({
      orgId: new Types.ObjectId(orgId),
      locationId: new Types.ObjectId(locationId),
      ...data,
    });
    return toExampleDTO(doc);
  },

  async getById(orgId: string, locationId: string, id: string): Promise<ExampleDTO | null> {
    const doc = await Example.findOne({
      _id: id,
      orgId: new Types.ObjectId(orgId),
      locationId: new Types.ObjectId(locationId),
    }).lean();
    return doc ? toExampleDTO(doc) : null;
  },

  async list(orgId: string, locationId: string): Promise<ExampleDTO[]> {
    const docs = await Example.find({
      orgId: new Types.ObjectId(orgId),
      locationId: new Types.ObjectId(locationId),
    }).lean();
    return docs.map(toExampleDTO);
  },
};
```

## DTO Conversion

```typescript
// src/types/example.ts
import type { Types } from "mongoose";

// What the database stores
interface ExampleDocument {
  _id: Types.ObjectId;
  orgId: Types.ObjectId;
  locationId: Types.ObjectId;
  name: string;
  createdAt: Date;
  updatedAt: Date;
}

// What the UI receives (plain object, serializable)
export interface ExampleDTO {
  id: string;
  orgId: string;
  locationId: string;
  name: string;
  createdAt: Date;
  updatedAt: Date;
}

// Converter function
export function toExampleDTO(doc: ExampleDocument): ExampleDTO {
  return {
    id: doc._id.toString(),
    orgId: doc.orgId.toString(),
    locationId: doc.locationId.toString(),
    name: doc.name,
    createdAt: doc.createdAt,
    updatedAt: doc.updatedAt,
  };
}
```

## TanStack Query Usage

```typescript
// In a Client Component
"use client";

import { useQuery, useMutation, useQueryClient } from "@tanstack/react-query";
import { getExamples, createExample } from "@/server/actions/example.actions";
import { toast } from "sonner";

// Query keys (consistent structure)
const exampleKeys = {
  all: ["examples"] as const,
  list: () => [...exampleKeys.all, "list"] as const,
  detail: (id: string) => [...exampleKeys.all, "detail", id] as const,
};

// Fetching
const { data, isLoading } = useQuery({
  queryKey: exampleKeys.list(),
  queryFn: async () => {
    const result = await getExamples();
    if (!result.success) throw new Error(result.error);
    return result.data;
  },
});

// Mutating with optimistic updates
const queryClient = useQueryClient();
const mutation = useMutation({
  mutationFn: createExample,
  onSuccess: (result) => {
    if (result.success) {
      queryClient.invalidateQueries({ queryKey: exampleKeys.list() });
      toast.success("Created successfully");
    } else {
      toast.error(result.error);
    }
  },
});
```

