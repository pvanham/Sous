# API Routes (Webhooks Only)

API routes are ONLY for external webhooks (Twilio, Clerk). All other data access uses Server Actions.

```typescript
// src/app/api/webhooks/twilio/route.ts
import { NextRequest, NextResponse } from "next/server";
import twilio from "twilio";

export async function POST(request: NextRequest) {
  // 1. Validate webhook signature
  const signature = request.headers.get("x-twilio-signature") ?? "";
  const body = await request.text();
  
  const isValid = twilio.validateRequest(
    process.env.TWILIO_AUTH_TOKEN!,
    signature,
    `${process.env.NEXT_PUBLIC_APP_URL}/api/webhooks/twilio`,
    Object.fromEntries(new URLSearchParams(body))
  );

  if (!isValid) {
    return NextResponse.json({ error: "Invalid signature" }, { status: 401 });
  }

  // 2. Process webhook
  const params = new URLSearchParams(body);
  const from = params.get("From");
  const messageBody = params.get("Body");

  // 3. Handle async (don't block response)
  // ... trigger processing

  // 4. Return TwiML response
  return new NextResponse(
    '<?xml version="1.0" encoding="UTF-8"?><Response></Response>',
    { headers: { "Content-Type": "text/xml" } }
  );
}
```

