// src/lib/validations/example.schema.ts
import { z } from "zod";

export const exampleSchema = z.object({
  name: z.string().min(2).max(100),
  email: z.string().email(),
  startTime: z.string().regex(/^([01]\d|2[0-3]):([0-5]\d)$/),
