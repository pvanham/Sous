{
  "name": "sous-monorepo",
  "private": true,
  "packageManager": "npm@11.13.0",
  "type": "module",
  "//engines": "Floor is 22.12.0 to match the Cloud Agent runtime, which ships Node 22 LTS at /exec-daemon/node and shadows nvm. Next 16 (>=20.9.0) and React Native 0.83 (>=20.19.4) both support Node 22, and install/typecheck/build are verified on it. .node-version still pins 24.15.0 for local devs; keep the upper bound at <25 until the toolchain is validated on Node 25.",
  "engines": {
    "node": ">=22.12.0 <25"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@sous/web",
    "dev:mobile": "turbo dev --filter=@sous/mobile",
    "dev:mobile:client": "npm run dev:client --workspace=@sous/mobile",
    "build:mobile:ios:dev": "npm run build:ios:dev --workspace=@sous/mobile",
    "build:mobile:ios:sim": "npm run build:ios:sim --workspace=@sous/mobile",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test:announcements-phase-3": "npm run test:announcements-phase-3 --workspace=@sous/web",
    "test:announcements-phase-4": "npm run test:announcements-phase-4 --workspace=@sous/web",
    "test:announcements-phase-5": "npm run test:announcements-phase-5 --workspace=@sous/web",
    "test:announcements-mobile": "npm run test:announcements-mobile --workspace=@sous/web",
    "test:announcement-composer-phase-2": "npm run test:announcement-composer-phase-2 --workspace=@sous/web",
    "verify:react": "node scripts/verify-react-singletons.mjs",
    "postinstall": "node scripts/verify-react-singletons.mjs"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "expo-router": "55.0.13",
    "postcss": "^8.5.13",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "lightningcss": "1.30.1",
    "turbo": "^2.5.0"
  },
  "//overrides": "react/react-dom/scheduler are pinned so the entire dependency tree — including transitive peer auto-installs — collapses to a single version. React Native 0.83.6 (Expo SDK 55) supports React 19.2.x and ships scheduler 0.27.0, so bump these pins only alongside @sous/mobile's expo/react-native versions.",
  "overrides": {
    "csstype": "3.2.3",
    "react": "$react",
    "react-dom": "$react-dom",
    "react-native": "0.83.6",
    "react-native-pager-view": "8.0.0",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "scheduler": "0.27.0",
    "expo-application": "~55.0.14",
    "expo-auth-session": "~55.0.15",
    "expo-constants": "~55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-linking": "~55.0.14",
    "expo-secure-store": "~55.0.13",
    "expo-web-browser": "~55.0.14",
    "lightningcss": "1.30.1"
  }
}
