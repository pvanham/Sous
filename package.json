{
  "name": "sous-monorepo",
  "private": true,
  "packageManager": "npm@11.7.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@sous/web",
    "dev:mobile": "turbo dev --filter=@sous/mobile",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "lightningcss": "1.30.1",
    "turbo": "^2.5.0"
  },
  "overrides": {
    "csstype": "3.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "expo-auth-session": "~7.0.10",
    "lightningcss": "1.30.1"
  }
}
