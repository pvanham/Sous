# ==========================================
# Sous (Next.js / Python / Docker) .gitignore
# ==========================================

# ────────────────────────────────────────────
# Node / JavaScript / TypeScript
# ────────────────────────────────────────────

# dependencies
node_modules/
.pnp/
.pnp.js
.pnp.cjs
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Next.js build output
.next/
out/

# Next.js auto-generated type declarations
next-env.d.ts

# TypeScript build artifacts
*.tsbuildinfo

# runtime / logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# package manager config (local overrides)
.npmrc
.yarnrc
.yarnrc.yml

# Vercel
.vercel/

# ────────────────────────────────────────────
# Python (solver service)
# ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
env/
.env.python
*.egg-info/
dist/
build/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ────────────────────────────────────────────
# Docker
# ────────────────────────────────────────────
# Uncomment if you have local docker volumes or overrides
# docker-compose.override.yml

# ────────────────────────────────────────────
# Environment / Secrets
# ────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.local.example

# Clerk (may include secrets)
/.clerk/

# ────────────────────────────────────────────
# Caches / Build Tooling
# ────────────────────────────────────────────
.turbo/
.swc/
.eslintcache
.cache/
.parcel-cache/

# ────────────────────────────────────────────
# Test / Coverage
# ────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ────────────────────────────────────────────
# OS / Editor / IDE
# ────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
._*
*~

# VS Code — ignore everything except shared extensions recommendation
.vscode/
!.vscode/extensions.json

# JetBrains (WebStorm, PyCharm, etc.)
.idea/

# ────────────────────────────────────────────
# AI / Agent Config (personal, not project)
# ────────────────────────────────────────────
.cursorrules
.agentrules
.antigravityrules
.gemini/
.claude/
.copilot/

# ────────────────────────────────────────────
# Misc
# ────────────────────────────────────────────
*.swp
*.swo
*.bak
*.tmp
*.orig
node_modules
